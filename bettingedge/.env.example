PORT=8000
DB_PATH=bettingedge.db
LOG_LEVEL=INFO

# Scraping Betclic — fenêtre horaire aléatoire autour de 06h00 (en minutes)
SCRAPE_WINDOW_MIN=-15
SCRAPE_WINDOW_MAX=30

# Kelly fractionné et plafond de mise
KELLY_KAPPA=0.25
MAX_STAKE_PCT=0.05

# Capital initial par portefeuille (€)
CAPITAL_INITIAL=1000.0

# Seuil EV minimum pour Stratégie A (absorbe l'erreur d'estimation)
EV_THRESHOLD_A=0.03

# Seuil EV minimum pour Stratégie B
EV_THRESHOLD_B=0.02

# Alerte Brier Score
BRIER_ALERT_THRESHOLD=0.22
